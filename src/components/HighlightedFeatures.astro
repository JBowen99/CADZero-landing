---
import { Image } from 'astro:assets';
import { HIGHLIGHTED_FEATURES } from '../data/highlighted-features';
import Reval from './ui/Reveal.astro';
import MockupFrame from './ui/MockupFrame.astro';
import Check from '@lucide/astro/icons/check';
import planetaryDriveExample from '../assets/planetary-drive-example.webp';
import selectionExample from '../assets/selection-example.webp';
import mountingPlateHistoryExample from '../assets/mounting-plate-history-example.webp';

const { class: className = '' } = Astro.props;

const visuals: Record<string, { src: ImageMetadata; alt: string }> = {
  chat: {
    src: planetaryDriveExample,
    alt: 'A planetary gear drive generated from a natural-language prompt',
  },
  viewport: {
    src: selectionExample,
    alt: 'Topology selection — faces, edges, and vertices picked directly in the 3D viewport',
  },
  export: {
    src: mountingPlateHistoryExample,
    alt: 'Mounting plate model with revision history panel showing versioned checkpoints',
  },
};
---

<section id="highlights" class={`relative py-24 scroll-mt-20 ${className}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Reval class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">Everything in one workspace</h2>
      <p class="mt-4 text-muted max-w-lg mx-auto">
        Three core pillars that make CADZero the most natural way to design in 3D.
      </p>
    </Reval>

    <div class="space-y-20 md:space-y-28">
      {HIGHLIGHTED_FEATURES.map((feature, i) => (
        <Reval :delay={i * 150}>
          <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
            <!-- Visual side -->
            <div
              class={`w-full lg:w-1/2 ${feature.imageOnLeft ? '' : 'lg:order-last'}`}
            >
              <MockupFrame glow class="w-full">
                <Image
                  src={visuals[feature.visual].src}
                  alt={visuals[feature.visual].alt}
                  sizes="(min-width: 1024px) 512px, 100vw"
                  class="block w-full h-auto"
                />
              </MockupFrame>
            </div>

            <!-- Text side -->
            <div class="w-full lg:w-1/2 space-y-4">
              <h3 class="text-2xl md:text-3xl font-semibold tracking-tight">
                {feature.title}
              </h3>
              <p class="text-muted leading-relaxed">
                {feature.description}
              </p>
              <ul class="space-y-2 pt-2">
                {feature.points.map((point) => (
                  <li class="flex items-start gap-3 text-sm text-foreground/80">
                    <span class="mt-0.5 w-5 h-5 rounded-full bg-brand/15 flex items-center justify-center shrink-0">
                      <Check class="w-3 h-3 text-brand" />
                    </span>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </Reval>
      ))}
    </div>
  </div>
</section>
