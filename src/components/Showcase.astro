---
import { Image } from 'astro:assets';
import Reval from './ui/Reveal.astro';
import MockupFrame from './ui/MockupFrame.astro';
import wireframeGearExample from '../assets/wireframe-gear-example.webp';
import codeExample from '../assets/code-example.webp';
import historyTab from '../assets/history-tab.webp';

const { class: className = '' } = Astro.props;

const gallery: { src: ImageMetadata; alt: string; caption: string }[] = [
  {
    src: wireframeGearExample,
    alt: '3D viewport showing a gear in wireframe view with orbit controls',
    caption: 'Wireframe & shaded views',
  },
  {
    src: codeExample,
    alt: 'CodeMirror editor showing generated parametric OpenSCAD and Build123D code',
    caption: 'Editable parametric code',
  },
  {
    src: historyTab,
    alt: 'Revision history panel with versioned checkpoints in a DAG graph',
    caption: 'Revision history',
  },
];
---

<section class={`relative py-24 overflow-hidden ${className}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Reval class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">See it in action</h2>
      <p class="mt-4 text-muted max-w-lg mx-auto">
        Here are some screenshots of the app in action.
      </p>
    </Reval>

    <Reval :delay={200}>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 max-w-5xl mx-auto">
        {gallery.map((shot, i) => (
          <MockupFrame
            glow={i === 0}
            class="group relative overflow-hidden aspect-[4/3]"
          >
            <Image
              src={shot.src}
              alt={shot.alt}
              sizes="(min-width: 1024px) 320px, 100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              class="block w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
            />
            <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-3 opacity-0 group-hover:opacity-100 transition-opacity">
              <span class="text-xs font-mono text-brand/90">&gt;</span>
              <span class="ml-1 text-xs text-foreground/80">{shot.caption}</span>
            </div>
          </MockupFrame>
        ))}
      </div>
    </Reval>
  </div>
</section>
